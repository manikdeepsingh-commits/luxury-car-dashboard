function buildMacanTab() {
  if (document.getElementById('macan-built').dataset.built === '1') return;
  document.getElementById('macan-built').dataset.built = '1';
  const firstBtn = document.querySelector('.macan-filter-btn');
  renderMacanListings('all', firstBtn);
  buildMacanMatrix();
}

function renderMacanListings(filter, btnEl) {
  const tbody = document.getElementById('macan-listings-body');
  tbody.innerHTML = '';
  document.querySelectorAll('.macan-filter-btn').forEach(b => b.classList.remove('active'));
  if (btnEl) btnEl.classList.add('active');
  let data = macanListings;
  if (filter === 'budget') data = macanListings.filter(l => l.atBudget);
  if (filter === 'gas') data = macanListings.filter(l => l.fuel === 'Gas');
  if (filter === 'cpo') data = macanListings.filter(l => l.cpo);
  data.sort((a,b) => a.price - b.price);
  data.forEach((l, i) => {
    const overBudget = !l.atBudget;
    const bg = overBudget ? 'opacity:0.75;' : '';
    const budgetTag = overBudget ? `<span style="background:#3a1a1a;color:#f87171;padding:2px 7px;border-radius:10px;font-size:10px;font-weight:700">$${Math.round((l.price-70000)/1000)}k over budget</span>` : `<span style="background:#1a3a1a;color:#4ade80;padding:2px 7px;border-radius:10px;font-size:10px;font-weight:700">✓ In budget</span>`;
    const cpoBadge = l.cpo ? '<span style="background:#1a3a2a;color:#4ade80;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600">CPO</span>' : '<span style="background:#1a2a3a;color:#60a5fa;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600">Dealer</span>';
    const fuelBadge = l.fuel === 'Electric' ? '<span style="background:#1f1a3a;color:#a78bfa;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600">⚡ EV</span>' : '<span style="background:#2a1f1a;color:#fb923c;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600">⛽ Gas</span>';
    const hpColor = l.hp >= 400 ? '#f87171' : l.hp >= 375 ? '#f59e0b' : '#60a5fa';
    const mo72 = monthly(l.price, 15, l.cpo ? 5.99 : 7.49, 72);
    const ratingIcon = l.rating === 'great' ? '🟢' : l.rating === 'good' ? '🟡' : '🔴';
    tbody.innerHTML += `<tr style="${bg}">
      <td style="font-weight:700;font-size:13px">${l.year} Macan <span style="color:var(--muted);font-size:11px">${l.trim}</span></td>
      <td>${fuelBadge}</td>
      <td style="font-weight:700;color:${hpColor}">${l.hp}hp</td>
      <td style="font-size:12px;color:var(--muted)">${l.km.toLocaleString()} km</td>
      <td><span style="font-weight:700;font-size:14px;color:${l.atBudget ? '#4ade80' : '#f87171'}">${fmt(l.price)}</span></td>
      <td>${budgetTag}</td>
      <td>${cpoBadge}</td>
      <td style="font-size:11px;color:var(--muted)">${l.location}</td>
      <td style="font-size:11px;color:var(--muted)">${l.dist}</td>
      <td style="font-size:12px;color:#60a5fa;font-weight:600">${fmt(mo72)}/mo</td>
      <td style="font-size:11px;color:var(--muted);max-width:180px">${l.note}</td>
      <td>${ratingIcon}</td>
      <td>${l.ato ? `<a href="${l.ato}" target="_blank" rel="noopener" style="display:inline-block;padding:4px 10px;background:#1a0d0d;color:#CC0000;border:1px solid #440000;border-radius:6px;font-size:11px;font-weight:600;text-decoration:none;white-space:nowrap">🔗 View</a>` : '<span style="color:var(--muted);font-size:11px">—</span>'}</td>
    </tr>`;
  });
  // Update shown count
  const el = document.getElementById('macan-count');
  if (el) el.textContent = data.length + ' listings';
}

function buildMacanMatrix() {
  const tbody = document.getElementById('macan-matrix-body');
  if (!tbody || tbody.innerHTML !== '') return;
  const scenarios = [
    { label:'2021 GTS CPO $44,995', price:44995, rate:5.99 },
    { label:'2022 Base $50,900', price:50900, rate:7.49 },
    { label:'2021 Base $52,987', price:52987, rate:7.49 },
    { label:'2023 Macan T $59,900', price:59900, rate:7.49 },
    { label:'2021 GTS VW Ottawa $61,915', price:61915, rate:7.49 },
    { label:'2022 Macan S CPO $66,900', price:66900, rate:5.99 },
    { label:'2024 Base $66,867', price:66867, rate:7.49 },
    { label:'2023 Macan S CPO $69,900', price:69900, rate:5.99 },
    { label:'2024 Macan S CPO $78,900 ⚠️', price:78900, rate:5.99 },
    { label:'2025 Base CPO $83,900 ⚠️', price:83900, rate:5.99 },
    { label:'2024 GTS 434hp $96,750 ⚠️', price:96750, rate:5.99 },
  ];
  scenarios.forEach(s => {
    const m60 = monthly(s.price, 15, s.rate, 60);
    const m72 = monthly(s.price, 15, s.rate, 72);
    const m84 = monthly(s.price, 15, s.rate, 84);
    const m72_20 = monthly(s.price, 20, s.rate, 72);
    const over = s.price > 70000;
    tbody.innerHTML += `<tr style="${over ? 'opacity:0.65' : ''}">
      <td style="font-weight:600;white-space:nowrap;font-size:12px">${s.label}</td>
      <td style="font-size:11px;color:var(--muted)">${s.rate}%</td>
      <td>${fmt(m60)}</td>
      <td><strong>${fmt(m72)}</strong></td>
      <td>${fmt(m84)}</td>
      <td style="color:var(--green)">${fmt(m72_20)}</td>
    </tr>`;
  });
}

// ============================================================
// INIT
// ============================================================
window.onload = () => {
  calcUpdate();
};
</script>
</body>
</html>
