// ============================================================
// TABS
// ============================================================
function showTab(name, el) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  el.classList.add('active');
  if (name === 'calculator') { buildMatrix(); calcUpdate(); }
  if (name === 'listings') buildListings();
  if (name === 'macan') { buildMacanTab(); showPorscheTab('overview', document.querySelector('#tab-macan .sub-tab')); }
}

function showPorscheTab(name, btnEl) {
  document.querySelectorAll('#tab-macan .sub-section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('#tab-macan .sub-tab').forEach(b => b.classList.remove('active'));
  const section = document.getElementById('porsche-' + name);
  if (section) section.classList.add('active');
  if (btnEl) btnEl.classList.add('active');
}

// ============================================================
// CARD FILTERS
// ============================================================
let activeType = 'all', activeBrand = 'all', activeBudget = 'all';

function updateCards() {
  const cards = document.querySelectorAll('.model-card');
  let shown = 0;
  cards.forEach(c => {
    const type = c.dataset.type;
    const brand = c.dataset.brand;
    const price = parseInt(c.dataset.price);
    let show = true;
    if (activeType !== 'all' && type !== activeType) show = false;
    if (activeBrand !== 'all' && brand !== activeBrand) show = false;
    if (activeBudget !== 'all' && price > parseInt(activeBudget)) show = false;
    c.classList.toggle('hidden', !show);
    if (show) shown++;
  });
  document.getElementById('card-count').textContent = shown + ' shown';
  document.getElementById('no-results').style.display = shown === 0 ? 'block' : 'none';
}

function filterType(val, btn) {
  activeType = val;
  document.querySelectorAll('.btn-filter').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  updateCards();
}
function filterBrand(val) { activeBrand = val; updateCards(); }
function filterBudget(val) { activeBudget = val; updateCards(); }

function sortCards(val) {
  const grid = document.getElementById('cards-grid');
  const cards = [...grid.querySelectorAll('.model-card')];
  if (val === 'price-asc') cards.sort((a,b) => a.dataset.price - b.dataset.price);
  else if (val === 'price-desc') cards.sort((a,b) => b.dataset.price - a.dataset.price);
  else if (val === 'value') cards.sort((a,b) => b.dataset.value - a.dataset.value);
  cards.forEach(c => grid.appendChild(c));
}

// ============================================================
// FINANCING CALCULATOR
// ============================================================
function fmt(n) { return '$' + Math.round(n).toLocaleString('en-CA'); }

function monthly(price, downPct, annualRate, months) {
  const taxed = price * 1.13;
  const down = price * (downPct / 100);
  const financed = taxed - down;
  const r = annualRate / 100 / 12;
  if (r === 0) return financed / months;
  return financed * r * Math.pow(1+r, months) / (Math.pow(1+r, months) - 1);
}

function calcUpdate() {
  const sel = document.getElementById('calc-model');
  const price = parseFloat(sel.value);
  const downPct = parseInt(document.getElementById('down-pct').value);
  const term = parseInt(document.getElementById('calc-term').value);
  const rate = parseFloat(document.getElementById('calc-rate').value);

  const taxed = price * 1.13;
  const down = price * (downPct / 100);
  const financed = taxed - down;
  const mo = monthly(price, downPct, rate, term);
  const totalPaid = down + mo * term;
  const totalInterest = totalPaid - taxed;

  document.getElementById('down-amt').textContent = fmt(down);
  document.getElementById('result-monthly').textContent = fmt(mo);
  document.getElementById('r-price').textContent = fmt(price);
  document.getElementById('r-hst').textContent = fmt(price * 0.13);
  document.getElementById('r-taxed').textContent = fmt(taxed);
  document.getElementById('r-down').textContent = fmt(down) + ' (' + downPct + '%)';
  document.getElementById('r-financed').textContent = fmt(financed);
  document.getElementById('r-interest').textContent = fmt(totalInterest);
  document.getElementById('r-total').textContent = fmt(totalPaid);
}

function buildMatrix() {
  const tbody = document.getElementById('matrix-body');
  if (tbody.innerHTML !== '') return;
  matrixData.forEach(row => {
    const m60 = monthly(row.price, 15, 7.49, 60);
    const m72 = monthly(row.price, 15, 7.49, 72);
    const m84 = monthly(row.price, 15, 7.49, 84);
    const mCpo = row.cpo ? monthly(row.price, 15, row.cpo, 72) : null;
    const overBudget = row.price > 70000;
    const highlight = overBudget ? ' style="opacity:0.6"' : '';
    tbody.innerHTML += `<tr${highlight}>
      <td class="model-col">${row.label}${overBudget ? ' <span style="color:var(--red);font-size:10px">over budget</span>' : ''}</td>
      <td>${fmt(row.price)}</td>
      <td>${fmt(m60)}/mo</td>
      <td><strong>${fmt(m72)}/mo</strong></td>
      <td>${fmt(m84)}/mo</td>
      <td>${mCpo ? '<span style="color:var(--green);font-weight:700">' + fmt(mCpo) + '/mo</span> <span style="color:var(--muted);font-size:10px">' + row.cpoLabel + '</span>' : '<span style="color:var(--muted)">—</span>'}</td>
    </tr>`;
  });
}

function jumpCalc(modelKey) {
  const tab = document.querySelector('.tab:nth-child(3)');
  showTab('calculator', tab);
  // Try to match model in select
  const sel = document.getElementById('calc-model');
  const keyMap = {
    'genesis-gv70': '49490', 'volvo-xc60': '51000', 'bmw-530i': '55000',
    'bmw-x5': '57800', 'mercedes-glc': '57500', 'lexus-rx350': '58500',
    'audi-q5': '58888', 'genesis-gv80': '59900', 'porsche-macan': '44995',
    'mercedes-eclass': '62000', 'audi-q7': '68000',
    'porsche-cayenne': '65900', 'porsche-boxster': '69800'
  };
  const target = keyMap[modelKey];
  if (target) {
    for (let i = 0; i < sel.options.length; i++) {
      if (sel.options[i].value === target) { sel.selectedIndex = i; break; }
    }
  }
  buildMatrix(); calcUpdate();
}

// ============================================================
// LISTINGS
// ============================================================
let listingsBrandFilter = 'all', listingsTypeFilter = 'all';

function buildListings() {
  renderListings();
}

function filterListings(val) { listingsBrandFilter = val; renderListings(); }
function filterListingsType(val) { listingsTypeFilter = val; renderListings(); }

function renderListings() {
  const tbody = document.getElementById('listings-body');
  tbody.innerHTML = '';
  const filtered = listings.filter(l => {
    if (listingsBrandFilter !== 'all' && l.brand !== listingsBrandFilter) return false;
    if (listingsTypeFilter !== 'all' && l.type !== listingsTypeFilter) return false;
    return true;
  });
  filtered.sort((a,b) => a.price - b.price);
  filtered.forEach(l => {
    const priceClass = l.value === 'great' ? 'price-good' : l.value === 'fair' ? 'price-high' : 'price-fair';
    const typeBadge = l.type === 'cpo' ? '<span class="listing-badge lb-cpo">CPO</span>' : '<span class="listing-badge lb-dealer">Dealer</span>';
    const valueIcon = l.value === 'great' ? '🟢 Great Deal' : l.value === 'good' ? '🟡 Good Price' : '🔴 Fair/Stretched';
    const brandColors = {genesis:'var(--genesis)',audi:'var(--audi)',bmw:'var(--bmw)',porsche:'var(--porsche)',mercedes:'var(--mercedes)',volvo:'#4d85b8',lexus:'var(--lexus)'};
    const dot = `<div style="display:inline-block;width:8px;height:8px;background:${brandColors[l.brand]||'#ccc'};border-radius:50%;margin-right:6px"></div>`;
    const linkCell = l.url ? `<a href="${l.url}" target="_blank" rel="noopener" style="display:inline-block;padding:4px 10px;background:#1a2a3a;color:#60a5fa;border:1px solid #2a3a50;border-radius:6px;font-size:11px;font-weight:600;text-decoration:none;white-space:nowrap" title="Search AutoTrader / Kijiji for this listing">🔗 View</a>` : '<span style="color:var(--muted);font-size:11px">—</span>';
    tbody.innerHTML += `<tr class="listing-row" data-brand="${l.brand}" data-type="${l.type}">
      <td>${dot}<strong>${l.model}</strong></td>
      <td>${l.year}</td>
      <td>${l.km} km</td>
      <td style="font-size:12px;color:var(--muted)">${l.trim}</td>
      <td><span class="price-tag ${priceClass}">${fmt(l.price)}</span><br><span style="font-size:10px;color:var(--muted)">+HST</span></td>
      <td>${typeBadge}</td>
      <td style="font-size:12px">${l.location}</td>
      <td style="font-size:12px;color:var(--muted)">${l.highlights}</td>
      <td style="font-size:12px">${valueIcon}</td>
      <td>${linkCell}</td>
    </tr>`;
  });
}

// ============================================================
// PORSCHE MACAN LISTINGS DATA
// ============================================================
const macanListings = [
